# Sessia environment example. Copy values into your hosting provider or local shell.

# Rails / database
APP_HOST=http://localhost:3000
DATABASE_URL=postgresql://localhost/sessia_production
RAILS_MASTER_KEY=
RAILS_SERVE_STATIC_FILES=true

# Resend transactional email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Sessia <no-reply@example.com>"

# Stripe SaaS billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_STUDIO=price_...

# Google Calendar session sync
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# Optional. Defaults to APP_HOST/google-calendar/callback in production routing.
GOOGLE_CALENDAR_REDIRECT_URI=

# Sessia AI assistant decision service
# Run ai-decision-service with SESSIA_AI_PROVIDER=mock for local demos or SESSIA_AI_PROVIDER=vercel for real Vercel AI SDK decisions.
SESSIA_AI_SERVICE_URL=http://127.0.0.1:8788/decide
SESSIA_AI_SERVICE_OPEN_TIMEOUT=3
SESSIA_AI_SERVICE_READ_TIMEOUT=30
SESSIA_AI_PROVIDER=mock
SESSIA_AI_MODEL_PROVIDER=openai
SESSIA_AI_MODEL=gpt-5-mini
OPENAI_API_KEY=sk-...

# Optional WhatsApp delivery through Twilio. Without these, AI messages are safely queued in Sessia.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WEBHOOK_URL=https://app.example.com/webhooks/twilio/whatsapp
TWILIO_STATUS_CALLBACK_URL=https://app.example.com/webhooks/twilio/whatsapp
TWILIO_VERIFY_WEBHOOK_SIGNATURE=true

# Optional operational config
RAILS_MAX_THREADS=5
