# Sessia environment example. Copy values into your hosting provider or local shell.

# Rails / database
APP_HOST=http://localhost:3000
DATABASE_URL=postgresql://localhost/sessia_production
RAILS_MASTER_KEY=
RAILS_SERVE_STATIC_FILES=true

# Resend transactional email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="Sessia <no-reply@example.com>"

# Stripe SaaS billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_STUDIO=price_...

# Google Calendar session sync
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# Optional. Defaults to APP_HOST/auth/google/callback.
GOOGLE_AUTH_REDIRECT_URI=
# Optional. Defaults to APP_HOST/google-calendar/callback in production routing.
GOOGLE_CALENDAR_REDIRECT_URI=

# Sessia AI assistant decision service
# Run ai-decision-service with SESSIA_AI_PROVIDER=mock for local demos or SESSIA_AI_PROVIDER=vercel for real Vercel AI SDK decisions through Vercel AI Gateway.
SESSIA_AI_SERVICE_URL=http://127.0.0.1:8788/decide
SESSIA_AI_SERVICE_OPEN_TIMEOUT=3
SESSIA_AI_SERVICE_READ_TIMEOUT=30
# Same strong random value in Rails and ai-decision-service. It authorizes read-only tool calls.
SESSIA_AI_TOOL_SECRET=
SESSIA_AI_PROVIDER=mock
SESSIA_AI_MODEL_PROVIDER=gateway
SESSIA_AI_MODEL=gpt-5-mini
AI_GATEWAY_API_KEY=...
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional WhatsApp delivery through Twilio. Without these, AI messages are safely queued in Sessia.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_WEBHOOK_URL=https://app.example.com/webhooks/twilio/whatsapp
TWILIO_STATUS_CALLBACK_URL=https://app.example.com/webhooks/twilio/whatsapp
TWILIO_VERIFY_WEBHOOK_SIGNATURE=true
# ContentSid values for templates created from WhatsappTemplateCatalog and approved in Twilio.
# Generate this block with: bin/rails sessia:twilio:templates:env
TWILIO_TEMPLATE_SESSION_CONFIRMATION_ES=
TWILIO_TEMPLATE_SESSION_CONFIRMATION_EN=
TWILIO_TEMPLATE_SESSION_FOLLOW_UP_ES=
TWILIO_TEMPLATE_SESSION_FOLLOW_UP_EN=
TWILIO_TEMPLATE_SESSION_REMINDER_ES=
TWILIO_TEMPLATE_SESSION_REMINDER_EN=
TWILIO_TEMPLATE_SESSION_FEEDBACK_ES=
TWILIO_TEMPLATE_SESSION_FEEDBACK_EN=
TWILIO_TEMPLATE_PAYMENT_REMINDER_ES=
TWILIO_TEMPLATE_PAYMENT_REMINDER_EN=
TWILIO_TEMPLATE_SESSION_CHANGE_ES=
TWILIO_TEMPLATE_SESSION_CHANGE_EN=
TWILIO_TEMPLATE_SESSION_CANCELED_ES=
TWILIO_TEMPLATE_SESSION_CANCELED_EN=

# Optional operational config
RAILS_MAX_THREADS=5
