SESSIA_AI_HOST=127.0.0.1
SESSIA_AI_PORT=8788
SESSIA_AI_PROVIDER=mock
SESSIA_AI_MODEL_PROVIDER=gateway
SESSIA_AI_MODEL=gpt-5-mini
SESSIA_AI_TIMEOUT_MS=30000
SESSIA_AI_MAX_RETRIES=1
SESSIA_AI_TEMPERATURE=0.2
SESSIA_AI_LOG_PROMPTS=false

# Required when SESSIA_AI_PROVIDER=vercel and SESSIA_AI_MODEL_PROVIDER=gateway
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Optional only if bypassing Vercel AI Gateway with SESSIA_AI_MODEL_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional Anthropic mode
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
