<section class="calendar-header">
  <div>
    <p class="eyebrow">Agenda</p>
    <h1><%= @period_title %></h1>
  </div>

  <div class="calendar-actions">
    <div class="segmented-control" aria-label="Calendar view">
      <%= link_to "Week", dashboard_path(view: "week", date: @selected_date.iso8601), class: @view_mode == "week" ? "active" : nil %>
      <%= link_to "Month", dashboard_path(view: "month", date: @selected_date.iso8601), class: @view_mode == "month" ? "active" : nil %>
    </div>
    <%= link_to "Previous", dashboard_path(view: @view_mode, date: @previous_date.iso8601), class: "secondary-button" %>
    <%= link_to "Today", dashboard_path(view: @view_mode, date: Date.current.iso8601), class: "secondary-button" %>
    <%= link_to "Next", dashboard_path(view: @view_mode, date: @next_date.iso8601), class: "secondary-button" %>
    <details class="agenda-block-menu">
      <summary class="secondary-button">Block time</summary>
      <div class="agenda-block-panel">
        <div class="section-heading compact">
          <div>
            <p class="eyebrow">Agenda</p>
            <h2>Blocked time</h2>
          </div>
        </div>
        <p class="panel-copy">
          Block time from the agenda. If a session is inside the block, Sessia cancels it and queues the AI to rebook with the client.
        </p>

        <%= form_with model: @schedule_block, url: dashboard_schedule_block_path, class: "form-stack" do |form| %>
          <%= hidden_field_tag :view, @view_mode %>
          <%= hidden_field_tag :date, @selected_date.iso8601 %>
          <div class="field">
            <%= form.label :title %>
            <%= form.text_field :title, placeholder: "Lunch, appointment, travel" %>
          </div>
          <div class="field">
            <%= form.label :starts_at, "Starts" %>
            <%= form.datetime_local_field :starts_at %>
          </div>
          <div class="field">
            <%= form.label :ends_at, "Ends" %>
            <%= form.datetime_local_field :ends_at %>
          </div>
          <div class="field">
            <%= form.label :notes %>
            <%= form.text_area :notes, rows: 3 %>
          </div>
          <div class="form-actions">
            <%= form.submit "Block time", class: "primary-button" %>
          </div>
        <% end %>

        <% if @schedule_blocks.any? %>
          <div class="blocked-time-list compact">
            <% @schedule_blocks.each do |block| %>
              <article>
                <div>
                  <strong><%= block.title %></strong>
                  <span><%= l(block.starts_at, format: :short) %> - <%= l(block.ends_at, format: :short) %></span>
                </div>
                <%= button_to "Remove", destroy_dashboard_schedule_block_path(block, view: @view_mode, date: @selected_date.iso8601), method: :delete, class: "ghost-button" %>
              </article>
            <% end %>
          </div>
        <% end %>
      </div>
    </details>
    <%= link_to "New session", new_session_path, class: "primary-button" %>
  </div>
</section>

<% if @view_mode == "month" %>
  <section class="month-calendar">
    <% Date::DAYNAMES.rotate(1).each do |day_name| %>
      <div class="month-weekday"><%= day_name.first(3) %></div>
    <% end %>

    <% @calendar_days.each do |day| %>
      <% day_sessions = @sessions_by_day.fetch(day, []) %>
      <%= link_to dashboard_path(view: "week", date: day.iso8601), class: "month-day #{'today' if day == Date.current} #{'outside-month' if day.month != @month_start.month}" do %>
        <header>
          <span><%= day.day %></span>
          <% if day == Date.current %>
            <strong>Today</strong>
          <% end %>
        </header>

        <div class="month-day-stats">
          <span><%= pluralize(day_sessions.size, "session") %></span>
          <span><%= pluralize(@free_slots_by_day.fetch(day), "free slot") %></span>
        </div>

        <div class="month-signal-summary" aria-label="Daily confirmation and payment summary">
          <span class="signal-count good"><%= confirmed_session_count(day_sessions) %> confirmed</span>
          <span class="signal-count danger"><%= unpaid_payment_count(day_sessions) %> unpaid</span>
        </div>
      <% end %>
    <% end %>
  </section>
<% else %>
  <section class="week-scheduler" aria-label="Weekly agenda by hourly slots">
    <div class="week-grid">
      <div class="week-grid-corner">Time</div>

      <% @calendar_days.each do |day| %>
        <% day_sessions = @sessions_by_day.fetch(day, []) %>
        <div class="week-grid-day <%= "today" if day == Date.current %>">
          <span><%= day.strftime("%a") %></span>
          <strong><%= day.day %></strong>
          <small><%= pluralize(day_sessions.size, "session") %></small>
        </div>
      <% end %>

      <% @time_slots.each do |slot_minutes| %>
        <div class="week-grid-time"><%= slot_time_label(slot_minutes) %></div>

        <% @calendar_days.each do |day| %>
          <% slot_start = calendar_slot_time(day, slot_minutes) %>
          <% slot_sessions = @sessions_by_slot.fetch([day, slot_minutes], []) %>

          <% if slot_sessions.any? %>
            <% session_record = slot_sessions.first %>
            <%= link_to session_path(session_record), class: "calendar-slot occupied #{slot_session_tone(session_record)}" do %>
              <div class="slot-main-line">
                <strong><%= session_record.client.name %></strong>
                <%= paid_session_icon(session_record) %>
              </div>
              <span><%= session_record.title %></span>
              <em><%= session_price(session_record) %></em>
              <small class="slot-time-range"><%= compact_session_time_range(session_record) %></small>
              <% if slot_sessions.size > 1 %>
                <b>+<%= slot_sessions.size - 1 %></b>
              <% end %>
            <% end %>
          <% else %>
            <% available_slot = @available_slots_by_key.fetch([day, slot_minutes], nil) %>
            <% if available_slot %>
              <%= link_to new_session_path(start_at: available_slot.starts_at.iso8601), class: "calendar-slot empty" do %>
                <span>Free</span>
              <% end %>
            <% else %>
              <div class="calendar-slot unavailable" aria-label="Unavailable time">
                <span>Unavailable</span>
              </div>
            <% end %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>

<section class="calendar-legend" aria-label="Calendar legend">
  <span><i class="slot-confirmed"></i> Confirmed</span>
  <span><i class="slot-pending"></i> Pending</span>
  <span><i class="slot-cancelled"></i> Cancelled</span>
  <span><i class="slot-paid">$</i> Paid</span>
</section>
