<!DOCTYPE html>
<html>
  <head>
    <title>Sessia</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag "favicon.png", type: "image/png" %>
    <%= favicon_link_tag "favicon.png", rel: "apple-touch-icon", type: "image/png" %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="<%= authenticated? ? "app-body" : "public-body" %>">
    <%= public_language_switcher %>
    <% if authenticated? %>
      <div class="app-shell">
        <aside class="sidebar">
          <%= link_to dashboard_path, class: "brand-lockup" do %>
            <span class="brand-mark">S</span>
            <span>
              <strong>Sessia</strong>
              <small><%= t("app.session_os") %></small>
            </span>
          <% end %>

          <nav class="sidebar-nav" aria-label="Primary navigation">
            <% nav_items.each do |label, path| %>
              <%= link_to label, path, class: nav_link_class(path) %>
            <% end %>
            <% if current_user.admin? %>
              <span class="sidebar-section-label">Platform</span>
              <% admin_nav_items.each do |label, path| %>
                <%= link_to label, path, class: nav_link_class(path) %>
              <% end %>
            <% end %>
          </nav>

          <div class="sidebar-footer" aria-label="<%= t("app.integrations.label") %>">
            <% mercado_pago_connected = current_user.mercado_pago_account&.connected? %>
            <%= link_to settings_path(anchor: "mercado-pago"), class: "sidebar-status-card", aria: { label: t("app.integrations.mercado_pago.aria") } do %>
              <span class="sidebar-integration-mark mercado-pago" aria-hidden="true">MP</span>
              <span class="sidebar-integration-copy">
                <strong>Mercado Pago</strong>
                <small><%= t("app.integrations.mercado_pago.copy") %></small>
              </span>
              <span class="sidebar-integration-state <%= mercado_pago_connected ? "connected" : "pending" %>" title="<%= t("app.integrations.states.#{mercado_pago_connected ? "connected" : "setup"}") %>"></span>
            <% end %>

            <% whatsapp_configured = current_user.ai_setting&.use_professional_whatsapp? %>
            <%= link_to settings_path(anchor: "professional-whatsapp"), class: "sidebar-status-card", aria: { label: t("app.integrations.whatsapp.aria") } do %>
              <span class="sidebar-integration-mark whatsapp" aria-hidden="true">WA</span>
              <span class="sidebar-integration-copy">
                <strong><%= t("app.integrations.whatsapp.title") %></strong>
                <small><%= t("app.integrations.whatsapp.copy") %></small>
              </span>
              <span class="sidebar-integration-state <%= whatsapp_configured ? "connected" : "pending" %>" title="<%= t("app.integrations.states.#{whatsapp_configured ? "connected" : "setup"}") %>"></span>
            <% end %>

            <% calendar_connected = current_user.calendar_connection&.connected? %>
            <% if google_calendar_feature_enabled? %>
              <%= link_to settings_path(anchor: "google-calendar"), class: "sidebar-status-card", aria: { label: t("app.integrations.google_calendar.aria") } do %>
                <span class="sidebar-integration-mark google-calendar" aria-hidden="true">G</span>
                <span class="sidebar-integration-copy">
                  <strong>Google Calendar</strong>
                  <small><%= t("app.integrations.google_calendar.copy") %></small>
                </span>
                <span class="sidebar-integration-state <%= calendar_connected ? "connected" : "pending" %>" title="<%= t("app.integrations.states.#{calendar_connected ? "connected" : "setup"}") %>"></span>
              <% end %>
            <% else %>
              <div class="sidebar-status-card disabled" aria-label="<%= t("app.integrations.google_calendar.unavailable_aria") %>">
                <span class="sidebar-integration-mark google-calendar" aria-hidden="true">G</span>
                <span class="sidebar-integration-copy">
                  <strong>Google Calendar</strong>
                  <small><%= t("app.integrations.google_calendar.coming_soon") %></small>
                </span>
                <span class="sidebar-integration-state unavailable" title="<%= t("app.integrations.states.coming_soon") %>"></span>
              </div>
            <% end %>
          </div>
        </aside>

        <div class="app-content">
          <header class="app-topbar">
            <div>
              <p><%= current_user.name %></p>
              <strong><%= topbar_title %></strong>
            </div>
            <div class="topbar-actions">
              <%= link_to t("actions.new_session"), new_session_path, class: "secondary-button" %>
              <details class="profile-menu">
                <summary aria-label="Open profile menu">
                  <span><%= current_user.name.first.upcase %></span>
                  <div>
                    <strong><%= current_user.name %></strong>
                    <small><%= current_user.email %></small>
                  </div>
                </summary>
                <div class="profile-menu-panel">
                  <%= link_to t("navigation.settings"), settings_path %>
                  <%= link_to t("navigation.ai_assistant"), ai_assistant_path %>
                  <%= link_to t("navigation.subscriptions"), subscription_path %>
                  <%= button_to t("auth.sign_out"), sign_out_path, method: :delete %>
                </div>
              </details>
            </div>
          </header>

          <main class="app-main">
            <%= render "shared/flash" %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <%= render "shared/flash" %>
      <%= yield %>
    <% end %>
  </body>
</html>
