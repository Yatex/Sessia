<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("payments.eyebrow") %></p>
    <h1><%= t("payments.title") %></h1>
  </div>
  <%= link_to t("navigation.subscriptions"), subscription_path, class: "secondary-button" %>
</section>

<section class="filter-panel">
  <%= form_with url: payments_path, method: :get, local: true, class: "filter-form" do %>
    <div class="filter-grid payments">
      <div class="field">
        <%= label_tag :client_id, t("payments.filters.client") %>
        <%= select_tag :client_id, options_from_collection_for_select(@payment_clients, :id, :name, @filters[:client_id]), include_blank: t("payments.filters.all_clients") %>
      </div>
      <div class="field">
        <%= label_tag :payment_status, t("payments.filters.status") %>
        <%= select_tag :payment_status, options_for_select([[t("payments.filters.all_statuses"), ""]] + PaymentRecord.statuses.keys.map { |status| [status == "pending" ? status_label("unpaid") : status_label(status), status] }, @filters[:payment_status]) %>
      </div>
      <div class="field">
        <%= label_tag :date_from, t("filters.from") %>
        <%= date_field_tag :date_from, @filters[:date_from] %>
      </div>
      <div class="field">
        <%= label_tag :date_to, t("filters.to") %>
        <%= date_field_tag :date_to, @filters[:date_to] %>
      </div>
    </div>
    <div class="filter-actions">
      <%= link_to t("filters.reset"), payments_path, class: "secondary-button" %>
      <%= submit_tag t("filters.apply"), class: "primary-button" %>
    </div>
  <% end %>
</section>

<section class="summary-grid two">
  <div class="metric-panel">
    <span><%= t("payments.summary.paid") %></span>
    <strong><%= @summary[:paid] %></strong>
  </div>
  <div class="metric-panel attention">
    <span><%= t("payments.summary.unpaid") %></span>
    <strong><%= @summary[:unpaid] %></strong>
  </div>
</section>

<section class="table-panel">
  <div class="section-heading">
    <h2><%= t("payments.clients.title") %></h2>
  </div>
  <% if @client_payment_rows.any? %>
    <table class="data-table payment-position-table">
      <thead>
        <tr>
          <th><%= t("payments.clients.client") %></th>
          <th><%= t("payments.clients.paid") %></th>
          <th><%= t("payments.clients.unpaid") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @client_payment_rows.each do |row| %>
          <tr>
            <td><strong><%= row[:client].name %></strong></td>
            <td>
              <span class="payment-position clear">
                <%= t("payments.classes", count: row[:paid_count]) %>
                <small><%= money_from_cents(row[:paid_cents]) %></small>
              </span>
            </td>
            <td>
              <span class="payment-position <%= row[:unpaid_count].positive? ? "behind" : "clear" %>">
                <%= t("payments.classes", count: row[:unpaid_count]) %>
                <small><%= money_from_cents(row[:unpaid_cents]) %></small>
              </span>
            </td>
            <td><%= link_to t("actions.open"), client_path(row[:client]), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state compact">
      <h2><%= t("payments.clients.empty_title") %></h2>
      <p><%= t("payments.clients.empty_body") %></p>
    </div>
  <% end %>
</section>

<section class="table-panel">
  <div class="section-heading">
    <h2><%= t("payments.sessions.title") %></h2>
  </div>
  <% if @sessions.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th><%= t("payments.sessions.session") %></th>
          <th><%= t("payments.sessions.client") %></th>
          <th><%= t("payments.sessions.date") %></th>
          <th><%= t("payments.sessions.status") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @sessions.each do |session_record| %>
          <tr>
            <td><strong><%= session_record.title %></strong></td>
            <td><%= session_record.client.name %></td>
            <td><%= l(session_record.start_time, format: :long) %></td>
            <td><%= payment_status_badge(session_record.payment_status) %></td>
            <td>
              <div class="table-actions">
                <% unless session_record.payment_paid? %>
                  <%= button_to t("payments.mark_paid"), mark_paid_session_path(session_record), method: :patch, class: "secondary-button compact" %>
                <% end %>
                <%= link_to t("actions.open"), session_path(session_record), class: "text-link" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state compact">
      <h2><%= t("payments.sessions.empty_title") %></h2>
      <p><%= t("payments.sessions.empty_body") %></p>
    </div>
  <% end %>
</section>
