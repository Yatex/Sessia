<main class="auth-page">
  <section class="auth-panel">
    <div class="auth-heading">
      <%= link_to "Sessia", root_path, class: "public-brand" %>
      <h1><%= t("auth.sign_in.title") %></h1>
      <p><%= t("auth.sign_in.copy") %></p>
    </div>

    <%= render "shared/google_auth_button", origin: "sign_in", label: t("auth.sign_in.google") %>
    <div class="auth-divider"><span><%= t("auth.or") %></span></div>

    <%= form_with url: sign_in_path, class: "form-stack" do |form| %>
      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, value: params[:email], autofocus: true, autocomplete: "email" %>
      </div>
      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autocomplete: "current-password" %>
      </div>
      <%= form.submit t("auth.sign_in.submit"), class: "primary-button full" %>
    <% end %>

    <div class="auth-links">
      <%= link_to t("auth.sign_up.submit"), sign_up_path %>
      <%= link_to t("auth.passwords.reset_title"), new_password_reset_path %>
    </div>
  </section>
</main>
