<main class="auth-page">
  <section class="auth-panel">
    <div class="auth-heading">
      <%= link_to "Sessia", root_path, class: "public-brand" %>
      <h1>Sign in</h1>
      <p>Open your session workspace.</p>
    </div>

    <%= render "shared/google_auth_button", origin: "sign_in", label: "Sign in with Google" %>
    <div class="auth-divider"><span>or</span></div>

    <%= form_with url: sign_in_path, class: "form-stack" do |form| %>
      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, value: params[:email], autofocus: true, autocomplete: "email" %>
      </div>
      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autocomplete: "current-password" %>
      </div>
      <%= form.submit "Sign in", class: "primary-button full" %>
    <% end %>

    <div class="auth-links">
      <%= link_to "Create account", sign_up_path %>
      <%= link_to "Reset password", new_password_reset_path %>
    </div>
  </section>
</main>
