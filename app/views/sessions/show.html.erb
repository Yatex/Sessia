<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("sessions.show.eyebrow") %></p>
    <h1><%= @session.title %></h1>
  </div>
  <div class="header-actions">
    <%= link_to t("sessions.show.edit"), edit_session_path(@session), class: "secondary-button" %>
    <%= link_to t("sessions.show.back_to_agenda"), dashboard_path(week: @session.start_time.to_date.iso8601), class: "primary-button" %>
  </div>
</section>

<section class="detail-layout">
  <aside class="detail-panel">
    <dl class="detail-list">
      <div><dt><%= t("sessions.show.client") %></dt><dd><%= link_to @session.client.name, client_path(@session.client), class: "text-link" %></dd></div>
      <div><dt><%= t("sessions.show.time") %></dt><dd><%= l(@session.start_time, format: :long) %><br><%= session_time_range(@session) %></dd></div>
      <div><dt><%= t("sessions.show.duration") %></dt><dd><%= t("sessions.show.minutes", count: @session.duration_minutes) %></dd></div>
      <div><dt><%= t("sessions.show.price") %></dt><dd><%= session_price(@session) %></dd></div>
      <div><dt><%= t("sessions.show.status") %></dt><dd><%= status_badge(@session.status) %></dd></div>
      <div><dt><%= t("sessions.show.confirmation") %></dt><dd><%= status_badge(@session.confirmation_status) %></dd></div>
      <div><dt><%= t("sessions.show.payment") %></dt><dd><%= payment_status_badge(@session.payment_status) %></dd></div>
      <% if google_calendar_feature_enabled? %>
        <div>
          <dt>Google Calendar</dt>
          <dd>
            <% if @session.google_calendar_event_id.present? %>
              <%= status_badge("synced") %>
              <br><small><%= @session.google_calendar_synced_at ? l(@session.google_calendar_synced_at, format: :short) : t("sessions.show.event_created") %></small>
            <% elsif @session.sync_to_google_calendar? %>
              <%= status_badge("pending") %>
            <% else %>
              <%= t("sessions.show.not_enabled") %>
            <% end %>
          </dd>
        </div>
      <% end %>
      <div><dt><%= t("sessions.show.recurring") %></dt><dd><%= @session.recurring? ? t("sessions.index.repeat.recurrent") : t("common.no") %></dd></div>
      <% if @session.recurring? %>
        <div><dt><%= t("sessions.show.generated_until") %></dt><dd><%= @session.recurrence_generated_until&.to_fs(:long) || @session.recurrence_ends_on&.to_fs(:long) || t("sessions.show.three_months_ahead") %></dd></div>
      <% elsif @session.generated_occurrence? %>
        <div><dt><%= t("sessions.show.series") %></dt><dd><%= link_to @session.parent_session.title, session_path(@session.parent_session), class: "text-link" %></dd></div>
      <% end %>
    </dl>
  </aside>

  <section class="detail-panel wide">
    <div class="section-heading">
      <h2><%= t("sessions.show.notes") %></h2>
      <%= link_to t("sessions.show.update"), edit_session_path(@session), class: "text-link" %>
    </div>
    <div class="notes-block">
      <%= simple_format(@session.notes.presence || t("common.no_notes")) %>
    </div>

    <% if google_calendar_feature_enabled? %>
      <div class="action-strip">
        <span>Google Calendar</span>
        <% if @calendar_connection&.connected? %>
          <p><%= t("sessions.show.google_calendar_copy") %></p>
          <%= button_to t("sessions.show.sync_google_calendar"), sync_google_calendar_session_path(@session), method: :post, class: "secondary-button" %>
          <% if @session.google_calendar_sync_error.present? %>
            <p class="field-hint calendar-error"><%= @session.google_calendar_sync_error %></p>
          <% end %>
        <% else %>
          <p><%= t("sessions.show.google_calendar_connect_copy") %></p>
          <%= link_to t("sessions.show.open_settings"), settings_path, class: "secondary-button" %>
        <% end %>
      </div>
    <% end %>

    <% charge = @session.main_charge %>
    <div class="action-strip payment-action-strip">
      <span>Mercado Pago</span>
      <p>
        <% if charge.present? %>
          <strong><%= money_from_cents(charge.amount_cents, charge.currency) %></strong>
          · <%= payment_status_badge(@session.payment_status) %>
          <% if charge.due_date.present? %>
            · Due <%= l(charge.due_date, format: :long) %>
          <% end %>
        <% elsif @session.priced? %>
          This priced session does not have a payment charge yet.
        <% else %>
          Add a price to generate a Mercado Pago payment link.
        <% end %>
      </p>

      <% if charge&.payment_url.present? %>
        <div class="copyable-link">
          <input type="text" readonly value="<%= charge.payment_url %>">
        </div>
      <% elsif current_user.mercado_pago_account&.connected? %>
        <%= button_to "Generate payment link", generate_payment_link_session_path(@session), method: :post, class: "secondary-button" %>
      <% else %>
        <p class="field-hint calendar-error">Connect Mercado Pago in Settings before generating client payment links.</p>
      <% end %>

      <div class="integration-actions">
        <% if charge.present? %>
          <%= button_to "Regenerate payment link", regenerate_payment_link_session_path(@session), method: :post, class: "secondary-button compact" %>
          <%= button_to "Waive payment", waive_payment_session_path(@session), method: :patch, class: "ghost-button compact" %>
          <%= button_to "Cancel charge", cancel_charge_session_path(@session), method: :patch, class: "ghost-button compact" %>
        <% end %>
      </div>

      <% if charge.present? %>
        <details class="manual-payment-details">
          <summary>Record manual payment</summary>
          <%= form_with url: record_manual_payment_session_path(@session), method: :post, class: "inline-payment-form" do |form| %>
            <%= form.number_field :amount, min: 0, step: "0.01", value: @session.price, aria: { label: "Amount" } %>
            <%= form.date_field :paid_on, value: Date.current.iso8601, aria: { label: "Paid on" } %>
            <%= form.select :method, [["Cash", "cash"], ["Transfer", "transfer"], ["Other", "other"]] %>
            <%= form.text_field :note, placeholder: "Note" %>
            <%= form.submit "Record payment", class: "secondary-button compact" %>
          <% end %>
        </details>

        <% if charge.payments.any? %>
          <div class="payment-history">
            <strong>Payment history</strong>
            <% charge.payments.recent.each do |payment| %>
              <p>
                <%= status_badge(payment.status) %>
                <%= money_from_cents(payment.amount_cents, payment.currency) %>
                <small><%= payment.paid_at ? l(payment.paid_at, format: :short) : l(payment.created_at, format: :short) %></small>
              </p>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div class="action-strip">
      <span><%= t("sessions.show.ai_ready") %></span>
      <p><%= t("sessions.show.ai_copy") %></p>
      <%= link_to t("sessions.show.open_ai_settings"), ai_assistant_path, class: "secondary-button" %>
    </div>
  </section>
</section>
