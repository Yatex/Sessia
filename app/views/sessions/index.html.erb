<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("sessions.index.eyebrow") %></p>
    <h1><%= t("sessions.index.title") %></h1>
  </div>
  <%= link_to t("actions.new_session"), new_session_path, class: "primary-button" %>
</section>

<section class="filter-panel">
  <%= form_with url: sessions_path, method: :get, local: true, class: "filter-form" do %>
    <div class="filter-grid sessions">
      <div class="field">
        <%= label_tag :client_id, t("sessions.index.filters.client") %>
        <%= select_tag :client_id, options_from_collection_for_select(@filter_clients, :id, :name, @filters[:client_id]), include_blank: t("sessions.index.filters.all_clients") %>
      </div>
      <div class="field">
        <%= label_tag :date_from, t("filters.from") %>
        <%= date_field_tag :date_from, @filters[:date_from] %>
      </div>
      <div class="field">
        <%= label_tag :date_to, t("filters.to") %>
        <%= date_field_tag :date_to, @filters[:date_to] %>
      </div>
      <div class="field">
        <%= label_tag :status, t("sessions.index.filters.status") %>
        <%= select_tag :status, options_for_select([[t("sessions.index.filters.all_statuses"), ""]] + Session.statuses.keys.map { |status| [status_label(status), status] }, @filters[:status]) %>
      </div>
      <div class="field">
        <%= label_tag :confirmation_status, t("sessions.index.filters.confirmation") %>
        <%= select_tag :confirmation_status, options_for_select([[t("sessions.index.filters.all_confirmations"), ""]] + Session.confirmation_statuses.keys.map { |status| [status_label(status), status] }, @filters[:confirmation_status]) %>
      </div>
      <div class="field">
        <%= label_tag :payment_status, t("sessions.index.filters.payment") %>
        <%= select_tag :payment_status, options_for_select([[t("sessions.index.filters.all_payments"), ""]] + Session.payment_statuses.keys.map { |status| [status == "pending" ? status_label("unpaid") : status_label(status), status] }, @filters[:payment_status]) %>
      </div>
      <div class="field">
        <%= label_tag :recurrence, t("sessions.index.filters.recurrence") %>
        <%= select_tag :recurrence, options_for_select([[t("sessions.index.filters.all_sessions"), ""], [t("sessions.index.filters.one_off"), "one_off"], [t("sessions.index.filters.recurrent"), "recurrent"], [t("sessions.index.filters.generated"), "generated"]], @filters[:recurrence]) %>
      </div>
    </div>
    <div class="filter-actions">
      <%= link_to t("filters.reset"), sessions_path, class: "secondary-button" %>
      <%= submit_tag t("filters.apply"), class: "primary-button" %>
    </div>
  <% end %>
</section>

<section class="table-panel">
  <% if @sessions.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th><%= t("sessions.index.table.when") %></th>
          <th><%= t("sessions.index.table.client") %></th>
          <th><%= t("sessions.index.table.title") %></th>
          <th><%= t("sessions.index.table.price") %></th>
          <th><%= t("sessions.index.table.status") %></th>
          <th><%= t("sessions.index.table.repeat") %></th>
          <th><%= t("sessions.index.table.confirmation") %></th>
          <th><%= t("sessions.index.table.payment") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @sessions.each do |session_record| %>
          <tr>
            <td><%= l(session_record.start_time, format: :long) %></td>
            <td><strong><%= session_record.client.name %></strong></td>
            <td><%= session_record.title %></td>
            <td><%= session_price(session_record) %></td>
            <td><%= status_badge(session_record.status) %></td>
            <td><%= session_record.recurring? ? t("sessions.index.repeat.recurrent") : (session_record.generated_occurrence? ? t("sessions.index.repeat.generated") : "-") %></td>
            <td><%= status_badge(session_record.confirmation_status) %></td>
            <td><%= payment_status_badge(session_record.payment_status) %></td>
            <td><%= link_to t("actions.open"), session_path(session_record), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <h2><%= t("sessions.index.empty_title") %></h2>
      <p><%= t("sessions.index.empty_body") %></p>
      <%= link_to t("sessions.index.schedule"), new_session_path, class: "primary-button" %>
    </div>
  <% end %>
</section>
