<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("clients.index.eyebrow") %></p>
    <h1><%= t("clients.index.title") %></h1>
  </div>
  <%= link_to t("clients.index.new_client"), new_client_path, class: "primary-button" %>
</section>

<section class="filter-panel">
  <%= form_with url: clients_path, method: :get, local: true, class: "filter-form" do %>
    <div class="filter-grid">
      <div class="field">
        <%= label_tag :query, t("clients.index.filters.search") %>
        <%= text_field_tag :query, @filters[:query], placeholder: t("clients.index.filters.search_placeholder") %>
      </div>
      <% if studio_workspace? %>
        <div class="field">
          <%= label_tag :user_id, t("team.professor") %>
          <%= select_tag :user_id, options_from_collection_for_select(@filter_professionals, :id, :name, @filters[:user_id]), include_blank: t("team.all_professors") %>
        </div>
      <% end %>
      <div class="field">
        <%= label_tag :status, t("clients.index.filters.status") %>
        <%= select_tag :status, options_for_select([[t("clients.index.filters.all_statuses"), ""]] + Client.statuses.keys.map { |status| [status_label(status), status] }, @filters[:status]) %>
      </div>
      <div class="field">
        <%= label_tag :linked, t("clients.index.filters.ai_whatsapp") %>
        <%= select_tag :linked, options_for_select([[t("clients.index.filters.all_clients"), ""], [t("clients.index.filters.linked"), "linked"], [t("clients.index.filters.not_linked"), "unlinked"]], @filters[:linked]) %>
      </div>
    </div>
    <div class="filter-actions">
      <%= link_to t("filters.reset"), clients_path, class: "secondary-button" %>
      <%= submit_tag t("filters.apply"), class: "primary-button" %>
    </div>
  <% end %>
</section>

<section class="table-panel">
  <% if @clients.any? %>
    <table class="data-table">
      <thead>
        <tr>
          <th><%= t("clients.index.table.name") %></th>
          <% if studio_workspace? %>
            <th><%= t("team.professor") %></th>
          <% end %>
          <th><%= t("clients.index.table.contact") %></th>
          <th><%= t("clients.index.table.preferred_channel") %></th>
          <th><%= t("clients.index.table.ai_whatsapp") %></th>
          <th><%= t("clients.index.table.status") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @clients.each do |client| %>
          <tr>
            <td><strong><%= client.name %></strong></td>
            <% if studio_workspace? %>
              <td><%= client.user.name %></td>
            <% end %>
            <td><%= client.display_contact %></td>
            <td><%= client.preferred_contact_channel.humanize %></td>
            <td><%= client.linked? ? status_badge("linked") : status_badge("not_linked") %></td>
            <td><%= status_badge(client.status) %></td>
            <td><%= link_to t("actions.open"), client_path(client), class: "text-link" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="empty-state">
      <h2><%= t("clients.index.empty_title") %></h2>
      <p><%= t("clients.index.empty_body") %></p>
      <%= link_to t("clients.index.create_client"), new_client_path, class: "primary-button" %>
    </div>
  <% end %>
</section>
