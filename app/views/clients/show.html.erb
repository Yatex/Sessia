<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("clients.show.eyebrow") %></p>
    <h1><%= @client.name %></h1>
  </div>
  <div class="header-actions">
    <%= link_to t("clients.show.edit"), edit_client_path(@client), class: "secondary-button" %>
    <%= link_to t("actions.new_session"), new_session_path(client_id: @client.id), class: "primary-button" %>
  </div>
</section>

<section class="detail-layout">
  <aside class="detail-panel">
    <dl class="detail-list">
      <div><dt><%= t("clients.show.email") %></dt><dd><%= @client.email.presence || t("common.not_set") %></dd></div>
      <div><dt>WhatsApp</dt><dd><%= @client.phone %></dd></div>
      <div><dt><%= t("clients.show.contact") %></dt><dd><%= @client.preferred_contact_channel.humanize %></dd></div>
      <div><dt><%= t("clients.show.ai_whatsapp") %></dt><dd><%= @client.linked? ? t("clients.show.linked_ago", time: time_ago_in_words(@client.linked_at)) : t("clients.show.waiting_message") %></dd></div>
      <div><dt><%= t("clients.show.status") %></dt><dd><%= status_badge(@client.status) %></dd></div>
    </dl>
    <div class="portal-link-panel">
      <h2><%= t("clients.show.whatsapp_start") %></h2>
      <p><%= t("clients.show.whatsapp_start_copy", name: @client.name) %></p>
      <% if (whatsapp_url = client_whatsapp_ai_start_url(@client)).present? %>
        <input readonly value="<%= whatsapp_url %>">
        <%= link_to t("clients.show.open_whatsapp"), whatsapp_url, class: "primary-button full", target: "_blank", rel: "noreferrer" %>
      <% else %>
        <input readonly value="<%= t("clients.show.whatsapp_env_missing") %>">
      <% end %>
    </div>
    <div class="notes-block">
      <h2><%= t("clients.show.notes") %></h2>
      <%= simple_format(@client.notes.presence || t("common.no_notes")) %>
    </div>
  </aside>

  <section>
    <div class="table-panel">
      <div class="section-heading">
        <h2>Billing</h2>
      </div>
      <div class="integration-status">
        <div>
          <span>Pending charges</span>
          <strong><%= @client.charges.unpaid.count %></strong>
        </div>
        <div>
          <span>Paid sessions</span>
          <strong><%= @client.sessions.where(payment_status: :paid).count %></strong>
        </div>
        <div>
          <span>Credit balance</span>
          <strong><%= money_from_cents(@client.credit_balance_cents, @billing_profile.currency.presence || "ARS") %></strong>
        </div>
      </div>

      <%= form_with model: @billing_profile, url: client_billing_profile_path(@client), method: :patch, class: "form-grid" do |form| %>
        <div class="field">
          <%= form.label :default_session_price, "Default session price" %>
          <%= form.number_field :default_session_price, min: 0, step: "0.01", inputmode: "decimal" %>
        </div>
        <div class="field">
          <%= form.label :currency %>
          <%= form.select :currency, Session::CURRENCIES.map { |currency| [currency, currency] } %>
        </div>
        <div class="field full-span">
          <label class="toggle-row compact">
            <%= form.check_box :payment_required_before_session %>
            <span>
              <strong>Payment required before session</strong>
              <small>New sessions for this client will inherit this setting.</small>
            </span>
          </label>
        </div>
        <div class="field">
          <%= form.label :default_due_timing, "Due timing" %>
          <%= form.select :default_due_timing, ClientBillingProfile.default_due_timings.keys.map { |key| [key.humanize, key] } %>
        </div>
        <div class="field">
          <%= form.label :custom_due_days_before, "Custom days before" %>
          <%= form.number_field :custom_due_days_before, min: 0 %>
        </div>
        <div class="field full-span">
          <%= form.label :notes %>
          <%= form.text_area :notes, rows: 3 %>
        </div>
        <div class="form-actions full-span">
          <%= form.submit "Save billing defaults", class: "secondary-button" %>
        </div>
      <% end %>
    </div>

    <div class="table-panel">
    <div class="section-heading">
      <h2><%= t("clients.show.recent_sessions") %></h2>
      <%= link_to t("clients.show.schedule"), new_session_path(client_id: @client.id), class: "text-link" %>
    </div>
    <% if @sessions.any? %>
      <table class="data-table">
        <thead>
          <tr><th><%= t("payments.sessions.date") %></th><th><%= t("sessions.index.table.title") %></th><th><%= t("sessions.index.table.price") %></th><th><%= t("sessions.index.table.confirmation") %></th><th><%= t("sessions.index.table.payment") %></th><th></th></tr>
        </thead>
        <tbody>
          <% @sessions.each do |session_record| %>
            <tr>
              <td><%= l(session_record.start_time, format: :long) %></td>
              <td><strong><%= session_record.title %></strong></td>
              <td><%= session_price(session_record) %></td>
              <td><%= status_badge(session_record.confirmation_status) %></td>
              <td><%= payment_status_badge(session_record.payment_status) %></td>
              <td><%= link_to t("actions.open"), session_path(session_record), class: "text-link" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state compact">
        <h2><%= t("clients.show.no_sessions_title") %></h2>
        <p><%= t("clients.show.no_sessions_body", name: @client.name) %></p>
      </div>
    <% end %>
    </div>
  </section>
</section>
