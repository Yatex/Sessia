<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("subscriptions.eyebrow") %></p>
    <h1><%= t("subscriptions.title") %></h1>
  </div>
  <% if current_user.stripe_customer_id.present? %>
    <%= button_to t("subscriptions.manage_stripe"), portal_subscription_path, method: :post, class: "secondary-button" %>
  <% end %>
</section>

<section class="billing-status">
  <div>
    <span><%= t("subscriptions.current_state") %></span>
    <strong><%= @subscription&.status ? status_label(@subscription.status) : t("subscriptions.no_subscription") %></strong>
  </div>
  <p>
    <%= @subscription&.period_label || t("subscriptions.choose_plan_copy") %>
    <strong class="client-count-inline"><%= t("subscriptions.active_clients", count: @active_client_count) %></strong>
  </p>
</section>

<% if @subscription&.provider == "trial" && @subscription.trial_ends_at.present? %>
  <section class="trial-banner">
    <div>
      <span class="status-badge trialing"><%= t("subscriptions.trial.active") %></span>
      <h2><%= t("subscriptions.trial.title") %></h2>
      <p>
        <%= t("subscriptions.trial.copy_html", date: @subscription.trial_ends_at.to_date.to_fs(:long)).html_safe %>
      </p>
    </div>
  </section>
<% end %>

<section class="plan-grid">
  <% @plans.each do |plan| %>
    <% fit_class = plan_fit_class(plan, @active_client_count) %>
    <article class="plan-card <%= fit_class %>">
      <span><%= plan.name %></span>
      <h2><%= plan.price %></h2>
      <strong class="plan-limit"><%= plan.client_limit_label %></strong>
      <p><%= plan.description %></p>
      <% if @recommended_plan&.tier == plan.tier %>
        <em class="plan-fit"><%= t("subscriptions.plan_fit.recommended") %></em>
      <% elsif fit_class == "over-limit" %>
        <em class="plan-fit"><%= t("subscriptions.plan_fit.over_limit") %></em>
      <% else %>
        <em class="plan-fit"><%= t("subscriptions.plan_fit.available") %></em>
      <% end %>

      <% if fit_class == "over-limit" %>
        <button class="secondary-button full" disabled><%= t("subscriptions.needs_larger") %></button>
      <% elsif plan_configured?(plan) %>
        <%= button_to t("subscriptions.choose", plan: plan.name), checkout_subscription_path(plan: plan.tier), method: :post, class: "primary-button full" %>
      <% else %>
        <button class="secondary-button full" disabled><%= t("subscriptions.set_env", env: plan.price_env_key) %></button>
      <% end %>
    </article>
  <% end %>
</section>
