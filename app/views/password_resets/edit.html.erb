<main class="auth-page">
  <section class="auth-panel">
    <div class="auth-heading">
      <%= link_to "Sessia", root_path, class: "public-brand" %>
      <h1>Choose a new password</h1>
      <p>Use at least eight characters.</p>
    </div>

    <%= render "shared/form_errors", object: @user %>

    <%= form_with model: @user, url: password_reset_path(token: params[:token]), method: :patch, class: "form-stack" do |form| %>
      <div class="field">
        <%= form.label :password %>
        <%= form.password_field :password, autofocus: true, autocomplete: "new-password" %>
      </div>
      <div class="field">
        <%= form.label :password_confirmation %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password" %>
      </div>
      <%= form.submit "Update password", class: "primary-button full" %>
    <% end %>
  </section>
</main>
