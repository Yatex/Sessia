<main class="auth-page">
  <section class="auth-panel">
    <div class="auth-heading">
      <%= link_to "Sessia", root_path, class: "public-brand" %>
      <h1><%= t("auth.passwords.reset_title") %></h1>
      <p><%= t("auth.passwords.reset_copy") %></p>
    </div>

    <%= form_with url: password_resets_path, class: "form-stack" do |form| %>
      <div class="field">
        <%= form.label :email %>
        <%= form.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>
      <%= form.submit t("auth.passwords.send_reset"), class: "primary-button full" %>
    <% end %>

    <p class="auth-switch"><%= link_to t("auth.passwords.back_to_sign_in"), sign_in_path %></p>
  </section>
</main>
