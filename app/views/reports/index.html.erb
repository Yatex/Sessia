<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("analytics.eyebrow") %></p>
    <h1><%= t("analytics.title") %></h1>
  </div>
</section>

<section class="summary-grid">
  <div class="metric-panel">
    <span><%= t("analytics.scheduled") %></span>
    <strong><%= @scheduled_count %></strong>
  </div>
  <div class="metric-panel">
    <span><%= t("analytics.completed") %></span>
    <strong><%= @completed_count %></strong>
  </div>
  <div class="metric-panel">
    <span><%= t("analytics.cancelled") %></span>
    <strong><%= @cancelled_count %></strong>
  </div>
  <div class="metric-panel attention">
    <span><%= t("analytics.payment_attention") %></span>
    <strong><%= @payment_pending_count %></strong>
  </div>
  <div class="metric-panel">
    <span><%= t("analytics.paid_revenue") %></span>
    <strong><%= money_from_cents(@paid_revenue_cents) %></strong>
  </div>
  <div class="metric-panel attention">
    <span><%= t("analytics.unpaid_revenue") %></span>
    <strong><%= money_from_cents(@unpaid_revenue_cents) %></strong>
  </div>
</section>
