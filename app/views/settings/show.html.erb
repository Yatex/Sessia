<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("navigation.settings") %></p>
    <h1><%= t("settings.title") %></h1>
  </div>
</section>

<section class="form-panel">
  <%= render "shared/form_errors", object: @user %>

  <%= form_with model: @user, url: settings_path, method: :patch, class: "form-grid", data: { settings_autosave: true } do |form| %>
    <div class="field">
      <%= form.label :name %>
      <%= form.text_field :name, autocomplete: "name" %>
    </div>
    <div class="field">
      <%= form.label :email %>
      <%= form.email_field :email, autocomplete: "email" %>
    </div>
    <div class="field">
      <%= form.label :locale, t("settings.language") %>
      <%= form.select :locale, language_options %>
    </div>
    <div class="field full-span">
      <%= form.label :time_zone, t("settings.timezone") %>
      <div class="inline-control">
        <%= form.select :time_zone, iana_time_zone_options %>
        <button type="button" class="secondary-button" data-use-detected-time-zone="#user_time_zone"><%= t("settings.use_browser_timezone") %></button>
      </div>
      <small class="field-hint">
        <%= t("settings.browser_detected") %>
        <strong data-time-zone-detected-label data-fallback-time-zone="<%= @user.time_zone %>"><%= @user.time_zone %></strong>.
      </small>
    </div>
    <div class="field full-span">
      <%= form.label :payment_instructions, t("settings.payment_methods.label") %>
      <%= form.text_area :payment_instructions, rows: 4, maxlength: 1500, placeholder: t("settings.payment_methods.placeholder") %>
      <small class="field-hint"><%= t("settings.payment_methods.hint") %></small>
    </div>
    <div class="form-actions full-span">
      <span class="autosave-status" data-autosave-status><%= t("settings.saved") %></span>
    </div>
  <% end %>
</section>

<section class="form-panel settings-integration-panel">
  <div class="section-heading">
    <div>
      <p class="eyebrow"><%= t("settings.communication") %></p>
      <h2><%= t("settings.owner_whatsapp.title") %></h2>
    </div>
    <% if @ai_setting.use_professional_whatsapp? %>
      <%= status_badge("connected") %>
    <% else %>
      <%= status_badge("not_connected") %>
    <% end %>
  </div>
  <p class="panel-copy">
    <%= t("settings.owner_whatsapp.copy") %>
  </p>

  <%= render "shared/form_errors", object: @ai_setting %>

  <%= form_with model: @ai_setting, url: professional_whatsapp_settings_path, method: :patch, class: "settings-form", data: { settings_autosave: true } do |form| %>
    <div class="whatsapp-settings-panel">
      <label class="toggle-row">
        <%= form.check_box :use_professional_whatsapp %>
        <span>
          <strong><%= t("settings.owner_whatsapp.enable") %></strong>
          <small><%= t("settings.owner_whatsapp.enable_copy") %></small>
        </span>
      </label>
      <div class="field">
        <%= form.label :professional_whatsapp_phone, t("settings.owner_whatsapp.phone") %>
        <%= form.telephone_field :professional_whatsapp_phone, placeholder: "+598 99 123 456", autocomplete: "tel" %>
      </div>
    </div>
    <div class="form-actions">
      <span class="autosave-status" data-autosave-status><%= t("settings.saved") %></span>
    </div>
  <% end %>
</section>

<section class="form-panel settings-availability-panel">
  <div class="section-heading">
    <div>
      <p class="eyebrow"><%= t("settings.availability.eyebrow") %></p>
      <h2><%= t("settings.availability.title") %></h2>
    </div>
  </div>
  <p class="panel-copy">
    <%= t("settings.availability.copy") %>
  </p>

  <%= form_with url: availability_settings_path, method: :patch, class: "settings-form", data: { settings_autosave: true } do %>
    <% availability_slots = (0...(24 * 60)).step(30).to_a %>
    <% selected_cells = {} %>
    <% @availability_by_weekday.each do |weekday, rules| %>
      <% rules.each do |rule| %>
        <% (rule.start_minute...rule.end_minute).step(30).each do |minute| %>
          <% selected_cells[[weekday, minute]] = true %>
        <% end %>
      <% end %>
    <% end %>

    <div class="availability-grid-editor" data-availability-grid data-available-label="<%= t("settings.availability.available") %>" data-closed-label="<%= t("settings.availability.closed") %>">
      <div class="availability-grid-head">
        <span></span>
        <% AvailabilityRule::WEEKDAY_LABELS.each do |_weekday, label| %>
          <strong><%= label.first(3) %></strong>
        <% end %>
      </div>

      <div class="availability-grid-body">
        <% availability_slots.each do |minute| %>
          <div class="availability-grid-row">
            <time><%= AvailabilityRule.time_label(minute) %></time>
            <% AvailabilityRule::WEEKDAY_LABELS.each do |weekday, label| %>
              <% value = "#{weekday}|#{AvailabilityRule.time_label(minute)}" %>
              <% checked = selected_cells[[weekday, minute]] %>
              <label class="availability-cell <%= "selected" if checked %>" title="<%= label %> <%= AvailabilityRule.time_label(minute) %>">
                <%= check_box_tag "availability_cells[]", value, checked, id: nil, data: { availability_cell: true } %>
                <span><%= checked ? t("settings.availability.available") : t("settings.availability.closed") %></span>
              </label>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="form-actions">
      <span class="autosave-status" data-autosave-status><%= t("settings.saved") %></span>
    </div>
  <% end %>
</section>

<section class="form-panel settings-integration-panel">
  <div class="section-heading">
    <div>
      <p class="eyebrow"><%= t("settings.integrations") %></p>
      <h2>Mercado Pago</h2>
    </div>
    <% if @mercado_pago_account&.connected? %>
      <%= status_badge("connected") %>
    <% elsif @mercado_pago_account&.expired? %>
      <%= status_badge("expired") %>
    <% elsif @mercado_pago_account&.error? %>
      <%= status_badge("error") %>
    <% else %>
      <%= status_badge("not_connected") %>
    <% end %>
  </div>
  <p class="panel-copy">
    <%= t("settings.mercado_pago.copy") %>
  </p>

  <% if @mercado_pago_account&.connected? %>
    <div class="integration-status">
      <div>
        <span><%= t("settings.mercado_pago.status") %></span>
        <strong><%= t("statuses.connected") %></strong>
      </div>
      <div>
        <span><%= t("settings.mercado_pago.provider_account") %></span>
        <strong><%= @mercado_pago_account.provider_user_id.presence || "Mercado Pago" %></strong>
      </div>
      <div>
        <span><%= t("settings.mercado_pago.connected_at") %></span>
        <strong><%= @mercado_pago_account.connected_at ? l(@mercado_pago_account.connected_at, format: :short) : t("settings.mercado_pago.ready") %></strong>
      </div>
    </div>
    <div class="integration-actions">
      <%= link_to t("settings.mercado_pago.reconnect"), connect_payment_accounts_mercado_pago_path, class: "secondary-button" %>
      <%= button_to t("settings.mercado_pago.disconnect"), disconnect_payment_accounts_mercado_pago_path, method: :delete, class: "ghost-button" %>
    </div>
  <% else %>
    <% if @mercado_pago_account&.last_error.present? %>
      <p class="field-hint calendar-error"><%= @mercado_pago_account.last_error %></p>
    <% end %>
    <% if @mercado_pago_configured %>
      <%= link_to t("settings.mercado_pago.connect"), connect_payment_accounts_mercado_pago_path, class: "primary-button" %>
    <% else %>
      <p class="field-hint calendar-error">
        <%= t("settings.mercado_pago.env_missing") %>
      </p>
    <% end %>
  <% end %>
</section>

<% if google_calendar_feature_enabled? %>
  <section class="form-panel settings-integration-panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow"><%= t("settings.integrations") %></p>
        <h2>Google Calendar</h2>
      </div>
      <% if @calendar_connection&.connected? %>
        <%= status_badge("connected") %>
      <% else %>
        <%= status_badge("not_connected") %>
      <% end %>
    </div>

    <% if @calendar_connection&.connected? %>
      <div class="integration-status">
        <div>
          <span><%= t("settings.google.connected_account") %></span>
          <strong><%= @calendar_connection.provider_account_email.presence || "Google Calendar" %></strong>
        </div>
        <div>
          <span><%= t("settings.google.calendar") %></span>
          <strong><%= @calendar_connection.calendar_id %></strong>
        </div>
        <div>
          <span><%= t("settings.google.last_sync") %></span>
          <strong><%= @calendar_connection.last_synced_at ? l(@calendar_connection.last_synced_at, format: :short) : t("settings.google.not_synced") %></strong>
        </div>
      </div>

      <%= form_with model: @calendar_connection, url: settings_google_calendar_path, method: :patch, class: "settings-form", data: { settings_autosave: true } do |form| %>
        <label class="toggle-row">
          <%= form.check_box :sync_sessions %>
          <span>
            <strong><%= t("settings.google.auto_add") %></strong>
            <small><%= t("settings.google.auto_add_copy") %></small>
          </span>
        </label>
        <div class="form-actions">
          <span class="autosave-status" data-autosave-status><%= t("settings.saved") %></span>
        </div>
      <% end %>

      <div class="integration-actions">
        <%= button_to t("settings.google.sync_upcoming"), sync_google_calendar_path, method: :post, class: "secondary-button" %>
        <%= button_to t("settings.google.disconnect"), disconnect_google_calendar_path, method: :delete, class: "ghost-button" %>
      </div>
      <% if @calendar_connection.error_message.present? %>
        <p class="field-hint calendar-error"><%= @calendar_connection.error_message %></p>
      <% end %>
    <% else %>
      <p class="panel-copy">
        <%= t("settings.google.connect_copy") %>
      </p>
      <% if @google_calendar_configured %>
        <%= link_to t("settings.google.connect"), connect_google_calendar_path, class: "primary-button" %>
      <% else %>
        <p class="field-hint calendar-error">
          <%= t("settings.google.env_missing") %>
        </p>
      <% end %>
    <% end %>
  </section>
<% end %>

<section class="form-panel settings-security-panel">
  <div class="section-heading">
    <div>
      <p class="eyebrow"><%= t("settings.security") %></p>
      <h2><%= t("settings.password_reset.title") %></h2>
    </div>
  </div>
  <p class="panel-copy">
    <%= t("settings.password_reset.copy_html", email: @user.email).html_safe %>
  </p>
  <%= button_to t("settings.password_reset.send"), password_reset_settings_path, method: :post, class: "secondary-button" %>
</section>
