<section class="page-header">
  <div>
    <p class="eyebrow"><%= t("ai_settings.eyebrow") %></p>
    <h1><%= t("ai_settings.title") %></h1>
  </div>
  <%= button_to t("ai_settings.run_now"), run_ai_assistant_path, method: :post, class: "secondary-button" %>
</section>

<section class="form-panel">
  <%= render "shared/form_errors", object: @ai_setting %>

  <%= form_with model: @ai_setting, url: ai_assistant_path, method: :patch, class: "settings-form" do |form| %>
    <div class="toggle-list">
      <label class="toggle-row">
        <%= form.check_box :confirm_sessions %>
        <span>
          <strong><%= t("ai_settings.toggles.confirm.title") %></strong>
          <small><%= t("ai_settings.toggles.confirm.copy") %></small>
        </span>
      </label>
      <label class="toggle-row">
        <%= form.check_box :send_pre_session_reminders %>
        <span>
          <strong><%= t("ai_settings.toggles.reminders.title") %></strong>
          <small><%= t("ai_settings.toggles.reminders.copy") %></small>
        </span>
      </label>
      <label class="toggle-row">
        <%= form.check_box :follow_up_no_response %>
        <span>
          <strong><%= t("ai_settings.toggles.follow_up.title") %></strong>
          <small><%= t("ai_settings.toggles.follow_up.copy") %></small>
        </span>
      </label>
      <label class="toggle-row">
        <%= form.check_box :ask_feedback_after_sessions %>
        <span>
          <strong><%= t("ai_settings.toggles.feedback.title") %></strong>
          <small><%= t("ai_settings.toggles.feedback.copy") %></small>
        </span>
      </label>
      <label class="toggle-row">
        <%= form.check_box :answer_basic_questions %>
        <span>
          <strong><%= t("ai_settings.toggles.questions.title") %></strong>
          <small><%= t("ai_settings.toggles.questions.copy") %></small>
        </span>
      </label>
      <label class="toggle-row">
        <%= form.check_box :escalate_important_conversations %>
        <span>
          <strong><%= t("ai_settings.toggles.escalate.title") %></strong>
          <small><%= t("ai_settings.toggles.escalate.copy") %></small>
        </span>
      </label>
      <label class="toggle-row muted">
        <%= form.check_box :payment_reminders %>
        <span>
          <strong><%= t("ai_settings.toggles.payments.title") %></strong>
          <small><%= t("ai_settings.toggles.payments.copy") %></small>
        </span>
      </label>
    </div>

    <div class="field">
      <%= form.label :instructions, t("ai_settings.instructions") %>
      <%= form.text_area :instructions, rows: 8, placeholder: t("ai_settings.instructions_placeholder") %>
    </div>

    <div class="form-actions">
      <%= form.submit t("ai_settings.save"), class: "primary-button" %>
    </div>
  <% end %>
</section>

<section class="ai-activity-grid">
  <div class="table-panel">
    <div class="section-heading">
      <h2><%= t("ai_settings.recent_tasks") %></h2>
      <span class="section-count"><%= @recent_ai_tasks.size %></span>
    </div>
    <% if @recent_ai_tasks.any? %>
      <table class="data-table compact-table">
        <thead>
          <tr><th><%= t("ai_settings.table.task") %></th><th><%= t("ai_settings.table.client") %></th><th><%= t("ai_settings.table.status") %></th><th><%= t("ai_settings.table.when") %></th></tr>
        </thead>
        <tbody>
          <% @recent_ai_tasks.each do |task| %>
            <tr>
              <td>
                <strong><%= task.automation_key.presence&.humanize || task.trigger_event.humanize %></strong>
                <small><%= task.activity_summary %></small>
              </td>
              <td><%= task.client&.name || t("ai_settings.no_client") %></td>
              <td><%= status_badge(task.status) %></td>
              <td><%= l(task.created_at, format: :short) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="empty-state compact">
        <h2><%= t("ai_settings.no_tasks_title") %></h2>
        <p><%= t("ai_settings.no_tasks_body") %></p>
      </div>
    <% end %>
  </div>

  <div class="table-panel">
    <div class="section-heading">
      <h2><%= t("ai_settings.escalations") %></h2>
      <span class="section-count"><%= @ai_alerts.size %></span>
    </div>
    <% if @ai_alerts.any? %>
      <div class="alert-list">
        <% @ai_alerts.each do |alert| %>
          <article class="ai-alert-card">
            <header>
              <strong><%= alert.title %></strong>
              <%= status_badge(alert.severity) %>
            </header>
            <p><%= alert.body %></p>
            <small><%= [alert.client&.name, alert.session&.title].compact.join(" · ") %></small>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state compact">
        <h2><%= t("ai_settings.no_escalations_title") %></h2>
        <p><%= t("ai_settings.no_escalations_body") %></p>
      </div>
    <% end %>
  </div>
</section>
