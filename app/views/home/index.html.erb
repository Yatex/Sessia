<header class="public-nav">
  <%= link_to root_path, class: "public-brand" do %>
    <span class="brand-mark">S</span>
    <strong>Sessia</strong>
  <% end %>
  <div class="public-actions">
    <%= link_to t("landing.nav.sign_in"), sign_in_path, class: "text-link" %>
    <%= link_to t("landing.nav.start_free"), sign_up_path, class: "primary-button" %>
  </div>
</header>

<main class="landing">
  <section class="landing-hero">
    <div class="hero-agenda-scene" aria-hidden="true">
      <div class="hero-agenda-toolbar">
        <span>Week of May 4</span>
        <strong>18 sessions</strong>
        <em>6 open slots</em>
      </div>
      <div class="hero-agenda-grid">
        <% [
          ["Mon", [["09:00", "Therapy", "confirmed paid"], ["13:00", "Coaching", "pending unpaid"]]],
          ["Tue", [["10:00", "Tutoring", "confirmed paid"], ["17:00", "Consulting", "confirmed unpaid"]]],
          ["Wed", [["08:00", "Training", "pending unpaid"], ["15:00", "Therapy", "confirmed paid"]]],
          ["Thu", [["11:00", "Coaching", "cancelled"], ["16:00", "Tutoring", "confirmed paid"]]],
          ["Fri", [["09:00", "Consulting", "confirmed paid"], ["14:00", "Feedback", "pending paid"]]],
          ["Sat", [["10:00", "Strategy", "confirmed unpaid"]]],
          ["Sun", []]
        ].each_with_index do |(day, sessions), index| %>
          <div class="hero-agenda-day <%= "is-today" if index == 2 %>">
            <header>
              <span><%= day %></span>
              <strong><%= sessions.size %></strong>
            </header>
            <% sessions.each do |time, title, tone| %>
              <div class="hero-agenda-session <%= tone.tr(" ", "-") %>">
                <small><%= time %></small>
                <b><%= title %></b>
                <i><%= tone.include?("paid") ? "$" : "!" %></i>
              </div>
            <% end %>
            <% if sessions.empty? %>
              <div class="hero-open-slot">Open day</div>
            <% else %>
              <div class="hero-open-slot compact"><%= 3 - sessions.size %> open slots</div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="hero-copy">
      <p class="eyebrow"><%= t("landing.hero.eyebrow") %></p>
      <h1>Sessia</h1>
      <p class="hero-lede">
        <%= t("landing.hero.lede") %>
      </p>
      <div class="hero-actions">
        <%= link_to t("landing.actions.create_account"), sign_up_path, class: "primary-button large" %>
        <%= link_to t("landing.nav.sign_in"), sign_in_path, class: "secondary-button large" %>
      </div>
    </div>
  </section>

  <section class="landing-proof" aria-label="Sessia product highlights">
    <article>
      <strong><%= t("landing.proof.week.title") %></strong>
      <span><%= t("landing.proof.week.body") %></span>
    </article>
    <article>
      <strong><%= t("landing.proof.whatsapp.title") %></strong>
      <span><%= t("landing.proof.whatsapp.body") %></span>
    </article>
    <article>
      <strong><%= t("landing.proof.billing.title") %></strong>
      <span><%= t("landing.proof.billing.body") %></span>
    </article>
  </section>

  <section class="landing-section">
    <div class="section-kicker">
      <p class="eyebrow"><%= t("landing.features.eyebrow") %></p>
      <h2><%= t("landing.features.heading") %></h2>
    </div>
    <div class="landing-feature-grid">
      <article>
        <span>01</span>
        <h3><%= t("landing.features.agenda.title") %></h3>
        <p><%= t("landing.features.agenda.body") %></p>
      </article>
      <article>
        <span>02</span>
        <h3><%= t("landing.features.clients.title") %></h3>
        <p><%= t("landing.features.clients.body") %></p>
      </article>
      <article>
        <span>03</span>
        <h3><%= t("landing.features.ai.title") %></h3>
        <p><%= t("landing.features.ai.body") %></p>
      </article>
      <article>
        <span>04</span>
        <h3><%= t("landing.features.payments.title") %></h3>
        <p><%= t("landing.features.payments.body") %></p>
      </article>
    </div>
  </section>

  <section class="landing-workflow">
    <div>
      <p class="eyebrow"><%= t("landing.workflow.eyebrow") %></p>
      <h2><%= t("landing.workflow.heading") %></h2>
      <p>
        <%= t("landing.workflow.body") %>
      </p>
      <%= link_to t("landing.actions.start_with_sessia"), sign_up_path, class: "primary-button large" %>
    </div>

    <div class="workflow-panel">
      <div class="workflow-row">
        <strong>08:00</strong>
        <span class="workflow-pill confirmed">Confirmed</span>
        <p>Therapy session</p>
        <em>Paid</em>
      </div>
      <div class="workflow-row">
        <strong>12:00</strong>
        <span class="workflow-pill blocked">Blocked</span>
        <p>Lunch break</p>
        <em>No booking</em>
      </div>
      <div class="workflow-row">
        <strong>15:00</strong>
        <span class="workflow-pill pending">Pending</span>
        <p>Tutoring follow-up</p>
        <em>Reminder queued</em>
      </div>
      <div class="workflow-row">
        <strong>18:00</strong>
        <span class="workflow-pill open">Open</span>
        <p>AI suggested slot</p>
        <em>Available</em>
      </div>
    </div>
  </section>

  <section class="landing-pricing">
    <div class="section-kicker">
      <p class="eyebrow"><%= t("landing.pricing.eyebrow") %></p>
      <h2><%= t("landing.pricing.heading") %></h2>
    </div>

    <div class="landing-pricing-grid">
      <% trial_plan = StripeBilling::TRIAL_PLAN %>
      <article class="landing-price-card trial">
        <span><%= trial_plan.name %></span>
        <h3><%= trial_plan.price %></h3>
        <strong><%= t("plans.trial.limit", count: trial_plan.client_limit) %></strong>
        <p><%= t("plans.trial.description") %></p>
        <%= link_to t("landing.pricing.start_trial"), sign_up_path, class: "primary-button full" %>
      </article>

      <% StripeBilling.plans.each do |plan| %>
        <article class="landing-price-card <%= "recommended" if plan.tier == "pro" %>">
          <span><%= plan.name %></span>
          <h3><%= plan.price %></h3>
          <strong><%= t("plans.client_limit", count: plan.client_limit, default: plan.client_limit_label) %></strong>
          <p><%= t("plans.#{plan.tier}.description", default: plan.description) %></p>
          <%= link_to plan.tier == "pro" ? t("landing.pricing.start_pro") : t("landing.pricing.choose", plan: plan.name), sign_up_path, class: plan.tier == "pro" ? "primary-button full" : "secondary-button full" %>
        </article>
      <% end %>
    </div>
  </section>

  <section class="landing-final-cta">
    <p class="eyebrow"><%= t("landing.final.eyebrow") %></p>
    <h2><%= t("landing.final.heading") %></h2>
    <div class="hero-actions">
      <%= link_to t("landing.actions.create_account"), sign_up_path, class: "primary-button large" %>
      <%= link_to t("landing.actions.have_account"), sign_in_path, class: "secondary-button large" %>
    </div>
  </section>
</main>
